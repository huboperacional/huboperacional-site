# Painel API base URL (publica, embutida no bundle Next.js)
NEXT_PUBLIC_PAINEL_URL=https://api.ads4pros.com

# GA4 Measurement ID (publico, embutido no bundle). Vazio/ausente = sem analytics
# e sem banner de consentimento. NAO usar o Measurement Protocol API secret aqui
# (site sem backend; secret nao vai pro client).
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
