# Multi-stage build pro Next.js 15 standalone.
# Stage 1: deps. Stage 2: build. Stage 3: runner minimal node-slim.
# Usa debian-slim em vez de alpine (fallback do pre-mortem — evita musl libc edge cases).

FROM node:20-slim AS deps
WORKDIR /app
COPY services/web/package*.json ./
RUN npm install --no-audit --no-fund

FROM node:20-slim AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY services/web/ ./
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

FROM node:20-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Standalone copia o que e' necessario; static em path separado
# public/ omitido (sem assets estaticos no MVP - favicon vira via metadata)
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

EXPOSE 3000
CMD ["node", "server.js"]
