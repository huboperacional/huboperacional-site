# syntax=docker/dockerfile:1
# Multi-stage build pro Next.js 15 standalone.
# Stage 1: deps. Stage 2: build. Stage 3: runner minimal node-slim.
# Usa debian-slim em vez de alpine (fallback do pre-mortem — evita musl libc edge cases).
# BuildKit cache mounts (canon v6.27.0 deploy-build-cache, opt-in): npm download cache + Next
# incremental build cache persist across builds, so the 2nd build onward runs ~1-3min vs ~7-8min
# cold. Font self-hosting from that recipe is N/A here: no next/font/google — fonts load via a
# runtime <link>, so there is no build-time font fetch to eliminate.

FROM node:20-slim AS deps
WORKDIR /app
COPY services/web/package*.json ./
RUN --mount=type=cache,target=/root/.npm npm ci --no-audit --no-fund

FROM node:20-slim AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY services/web/ ./
ENV NEXT_TELEMETRY_DISABLED=1
# NEXT_PUBLIC_* are inlined into the client bundle at build time, so the GA4 id must
# be present HERE (not just at runtime in compose). Default is the public prod
# Measurement id; override with --build-arg NEXT_PUBLIC_GA_ID= (empty) to disable
# analytics for staging/preview builds.
ARG NEXT_PUBLIC_GA_ID=G-K60P2FZ61K
ENV NEXT_PUBLIC_GA_ID=$NEXT_PUBLIC_GA_ID
# Meta Pixel id (marketing) — public client-side id, same as the GA id above. Default is the
# prod Pixel, so the consent banner then covers analytics + marketing. Override with
# --build-arg NEXT_PUBLIC_META_PIXEL_ID= (empty) to disable the Pixel for staging/preview.
ARG NEXT_PUBLIC_META_PIXEL_ID=641491994507686
ENV NEXT_PUBLIC_META_PIXEL_ID=$NEXT_PUBLIC_META_PIXEL_ID
RUN --mount=type=cache,target=/app/.next/cache npm run build

FROM node:20-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

# Standalone copia o que e' necessario; static + public em paths separados
# (standalone NAO inclui public/ automaticamente — precisa copiar manualmente).
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000
CMD ["node", "server.js"]
